# Use the local JDK (Java 25) for both compilation and runtime.
# tool_java_runtime_version controls which JDK runs javac (the compiler).
# java_runtime_version controls which JDK runs the compiled code.
build --java_runtime_version=local_jdk
build --tool_java_runtime_version=local_jdk
build --action_env=BAZEL_SH="C:/Program Files/Git/bin/bash.exe"
